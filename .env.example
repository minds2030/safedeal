# ── .env.example ─────────────────────────────────────────────
# Copy this to .env and fill in your values

# ── Telegram ──────────────────────────────────────────────────
BOT_TOKEN=7123456789:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MINIAPP_URL=https://yourdomain.com/app

# ── Platform wallets (your revenue goes here) ─────────────────
PLATFORM_WALLET_EVM=0xYourEVMWalletAddress
PLATFORM_WALLET_TON=UQYourTONWalletAddress

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost/safedeal

# ── EVM RPC (you can use free Ankr/Infura/Alchemy endpoints) ──
RPC_ETHEREUM=https://rpc.ankr.com/eth
RPC_BSC=https://bsc-dataseed.binance.org
RPC_POLYGON=https://polygon-rpc.com
RPC_BASE=https://mainnet.base.org
RPC_SEPOLIA=https://rpc.sepolia.org
RPC_BSC_TEST=https://data-seed-prebsc-1-s1.binance.org:8545

# ── Deployed contract addresses (fill after deployment) ───────
CONTRACT_ETHEREUM=
CONTRACT_BSC=
CONTRACT_POLYGON=
CONTRACT_BASE=
CONTRACT_SEPOLIA=
CONTRACT_BSC_TEST=

# ── TON ───────────────────────────────────────────────────────
TON_ENDPOINT=https://toncenter.com/api/v2/jsonRPC
TON_API_KEY=your_toncenter_api_key
TON_CONTRACT_ADDR=
TON_TESTNET_ENDPOINT=https://testnet.toncenter.com/api/v2/jsonRPC
TON_TESTNET_CONTRACT=

# ── Bot wallet (for auto-release — keep SECRET!) ──────────────
BOT_PRIVATE_KEY=0xYourEVMPrivateKey
BOT_TON_MNEMONIC=word1 word2 word3 ... word24
